{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "roots": ["<rootDir>/src", "<rootDir>/test"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/generated/prisma/(.*)$": "<rootDir>/dist/src/generated/prisma/$1",
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
